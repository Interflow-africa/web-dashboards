# ─── Interflow Frontend — Environment Variables ───────────────────
#
# MODES:
#   Mock  → VITE_USE_MOCK=true   (no backend needed, all data is fake)
#   Dev   → VITE_USE_MOCK=false  + VITE_API_URL=https://web-development-eb7a.up.railway.app/api/v1
#   Prod  → VITE_USE_MOCK=false  + VITE_API_URL=https://<production-domain>/api/v1
#
# Copy this file to .env.local and fill in values.

VITE_API_URL=https://web-development-eb7a.up.railway.app/api/v1
VITE_USE_MOCK=false
